# ==============================
# Monorepo Root .gitignore
# ==============================

# General
.DS_Store
Thumbs.db
*.log

# ==============================
# Backend (Python / FastAPI)
# ==============================
# Environments
backend/.env
backend/.venv/
backend/venv/
backend/env/
.env

# Cache & Compiled
__pycache__/
*.py[cod]
*$py.class
*.so
.pytest_cache/
.coverage
htmlcov/

# Models & Data (Ignore large files & raw data)
backend/data/raw/
backend/data/scrap/
backend/data/fetch/

# Abaikan ML Models (Gunakan DVC / DagsHub)
backend/models/*.pkl
backend/models/*.bin
backend/models/*.h5

# ==============================
# Frontend (Node / Next.js)
# ==============================
# Dependencies
frontend/node_modules/
node_modules/

# Next.js build output
frontend/.next/
frontend/out/

# Environment files
frontend/.env
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Vercel
.vercel
